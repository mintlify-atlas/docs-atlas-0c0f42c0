  "keyFeatures": [
    "CSS and JavaScript code inspection from Figma selections",
    "Deep select mode for easier node selection in read-only views",
    "Measure to selection mode for spacing visualization",
    "Customizable plugin system for code transformation",
    "MCP server for AI agent and IDE integration",
    "Configurable CSS units (px, rem) and root font size",
    "Variable display modes (Reference/Resolved/Both)",
    "Scroll selection into view feature"
  ],
  "publicApiSurface": [
    "definePlugin() - Create custom plugins",
    "transform() - Transform style object/code to string",
    "transformVariable() - Convert CSS variables to alternate formats",
    "transformPx() - Convert pixel values to other units",
    "transformComponent() - Convert design components to dev components",
    "get_code - MCP tool for high-fidelity code output",
    "get_structure - MCP tool for structural outline",
    "@tempad-dev/plugins - Plugin SDK package",
    "@tempad-dev/mcp - MCP server package"
  ]
